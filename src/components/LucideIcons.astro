---
// Lucide Icons Component - renders icons client-side
// Optimized to load once and apply to all icons in the page
---

<div class="lucide-icons-container">
	<slot />
</div>

<script>
	import { createIcons, icons } from 'lucide';

	// Initialize icons after page load
	document.addEventListener('DOMContentLoaded', () => {
		createIcons({
			icons,
			attrs: {
				'aria-hidden': 'true',
				'focusable': 'false',
			},
		});
	});
</script>

<style>
	/* Ensure icons inherit color from parent */
	.lucide-icons-container svg {
		display: inline-block;
		vertical-align: middle;
	}
</style>
