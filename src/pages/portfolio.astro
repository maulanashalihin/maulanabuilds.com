                                        xmlns="http://www.w3.org/2000/svg"
                                        xmlns:xlink="http://www.w3.org/1999/xlink"
                                        ><defs
                                            ><linearGradient
                                                id="dripform-gradient"
                                                x1="5.21"
                                                y1="64.96"
                                                x2="54.95"
                                                y2="7.9"
                                                gradientUnits="userSpaceOnUse"
                                                ><stop
                                                    offset="0"
                                                    stop-color="#9536eb"
                                                ></stop><stop
                                                    offset="1"
                                                    stop-color="#ff3d84"
                                                ></stop></linearGradient
                                            ></defs
                                        ><path
                                            fill="url(#dripform-gradient)"
                                            d="M0,6.28V63.97c0,3.47,2.81,6.28,6.28,6.28H45.93c15.9,0,28.79-12.89,28.79-28.79v-12.68C74.71,12.89,61.82,0,45.93,0H6.28C2.81,0,0,2.81,0,6.28Z"
                                        ></path><rect
