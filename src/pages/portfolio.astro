---
import Layout from "../layouts/Layout.astro";
import LucideIcons from "../components/LucideIcons.astro";
import Header from "../components/Header.astro";
import BackToTop from "../components/BackToTop.astro";
---

<Layout>
    <Header />
    <LucideIcons>
        <main id="main-content" class="min-h-screen">
            <!-- Hero Section -->
            <section class="max-w-7xl mx-auto px-6 pt-32 pb-16">
                <div class="max-w-4xl">
                    <div
                        class="inline-flex items-center gap-2 border border-[#2A2F3A] bg-[#14181F] text-cyan-400 px-4 py-1.5 rounded-full text-sm mb-8"
                    >
                        <i data-lucide="folder-open" class="w-4 h-4"></i>
                        Portfolio Archive
                    </div>
                    <h1
                        class="text-4xl md:text-6xl font-bold tracking-tighter leading-[1.1] mb-6"
                    >
                        Proof of Work.
                    </h1>
                    <p class="text-xl text-gray-400 max-w-3xl leading-relaxed">
                        I don't just write code; I build products. Every project
                        below represents a <strong class="text-gray-300"
                            >production-ready system</strong
                        > shipped with proper architecture, security, and documentation.
                    </p>
                </div>
            </section>

            <!-- Portfolio Grid -->
            <section class="max-w-7xl mx-auto px-6 pb-24">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
                >
                    <!-- Laju.dev -->
                    <a
                        href="https://laju.dev"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block group border border-[#2A2F3A] bg-[#0A0D12] rounded-2xl overflow-hidden hover:border-cyan-500 transition duration-300 hover:shadow-[0_0_30px_rgba(34,211,238,0.1)]"
                    >
                        <div class="p-8">
                            <div class="flex items-center gap-4 mb-4">
                                <div
                                    class="bg-[#14181F] p-3 rounded-lg border border-[#2A2F3A] group-hover:border-cyan-800 transition"
                                >
                                    <img
                                        src="/laju.png"
                                        alt="Laju.dev logo"
                                        loading="lazy"
                                        width="32"
                                        height="32"
                                        class="w-8 h-8 object-contain"
                                    />
                                </div>
                                <div>
                                    <h3
                                        class="text-xl font-bold text-gray-200 group-hover:text-cyan-400 transition"
                                    >
                                        Laju.dev
                                    </h3>
                                    <span class="text-xs text-gray-500"
                                        >AI-Native Full-Stack Framework</span
                                    >
                                </div>
                            </div>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                I engineered my own TypeScript framework to ship
                                products 10x faster. It handles an extreme 258k
                                req/sec (11x faster than Express) with built-in
                                auth, SQLite, and AI workflows.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="text-xs font-mono text-cyan-400 bg-cyan-950/30 border border-cyan-900/50 px-2 py-1 rounded"
                                    >TypeScript</span
                                >
                                <span
                                    class="text-xs font-mono text-gray-400 bg-[#1A1F26] px-2 py-1 rounded"
                                    >Svelte 5</span
                                >
                                <span
                                    class="text-xs font-mono text-gray-400 bg-[#1A1F26] px-2 py-1 rounded"
                                    >AI-Native</span
                                >
                            </div>
                        </div>
                        <div
                            class="px-8 py-4 border-t border-[#2A2F3A] bg-[#0F131A] flex items-center justify-between"
                        >
                            <span class="text-xs text-gray-500"
                                >Visit Project</span
                            >
                            <i
                                data-lucide="external-link"
                                class="w-4 h-4 text-cyan-500 group-hover:translate-x-1 transition-transform"
                            ></i>
                        </div>
                    </a>

                    <!-- Velist.dev -->
                    <a
                        href="https://velist.dev"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block group border border-[#2A2F3A] bg-[#0A0D12] rounded-2xl overflow-hidden hover:border-cyan-500 transition duration-300 hover:shadow-[0_0_30px_rgba(34,211,238,0.1)]"
                    >
                        <div class="p-8">
                            <div class="flex items-center gap-4 mb-4">
                                <div
                                    class="bg-[#14181F] p-3 rounded-lg border border-[#2A2F3A] group-hover:border-cyan-800 transition"
                                >
                                    <img
                                        src="/velist.png"
                                        alt="Velist.dev logo"
                                        loading="lazy"
                                        width="32"
                                        height="32"
                                        class="w-8 h-8 object-contain"
                                    />
                                </div>
                                <div>
                                    <h3
                                        class="text-xl font-bold text-gray-200 group-hover:text-cyan-400 transition"
                                    >
                                        Velist.dev
                                    </h3>
                                    <span class="text-xs text-gray-500"
                                        >Multi-Agent AI Collaboration</span
                                    >
                                </div>
                            </div>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                Built the latest AI-native fullstack framework
                                designed for multi-agent workflows. Goes from
                                zero-to-production in minutes with mandatory
                                human review points.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="text-xs font-mono text-cyan-400 bg-cyan-950/30 border border-cyan-900/50 px-2 py-1 rounded"
                                    >Bun</span
                                >
                                <span
                                    class="text-xs font-mono text-gray-400 bg-[#1A1F26] px-2 py-1 rounded"
                                    >Elysia</span
                                >
                                <span
                                    class="text-xs font-mono text-gray-400 bg-[#1A1F26] px-2 py-1 rounded"
                                    >Svelte 5</span
                                >
                            </div>
                        </div>
                        <div
                            class="px-8 py-4 border-t border-[#2A2F3A] bg-[#0F131A] flex items-center justify-between"
                        >
                            <span class="text-xs text-gray-500"
                                >Visit Project</span
                            >
                            <i
                                data-lucide="external-link"
                                class="w-4 h-4 text-cyan-500 group-hover:translate-x-1 transition-transform"
                            ></i>
                        </div>
                    </a>

                    <!-- Antre.in -->
                    <a
                        href="https://antre.in"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block group border border-[#2A2F3A] bg-[#0A0D12] rounded-2xl overflow-hidden hover:border-cyan-500 transition duration-300 hover:shadow-[0_0_30px_rgba(34,211,238,0.1)]"
                    >
                        <div class="p-8">
                            <div class="flex items-center gap-4 mb-4">
                                <div
                                    class="bg-[#14181F] p-3 rounded-lg border border-[#2A2F3A] group-hover:border-cyan-800 transition"
                                >
                                    <img
                                        src="/antrein.png"
                                        alt="Antre.in logo"
                                        loading="lazy"
                                        width="32"
                                        height="32"
                                        class="w-8 h-8 object-contain"
                                    />
                                </div>
                                <div>
                                    <h3
                                        class="text-xl font-bold text-gray-200 group-hover:text-cyan-400 transition"
                                    >
                                        Antre.in
                                    </h3>
                                    <span class="text-xs text-gray-500"
                                        >B2B Healthcare SaaS</span
                                    >
                                </div>
                            </div>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                A live, cloud-based queue management SaaS
                                serving healthcare and service businesses.
                                Features a digital waiting room, booking logic,
                                notifications, and cashier integration.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="text-xs font-mono text-cyan-400 bg-cyan-950/30 border border-cyan-900/50 px-2 py-1 rounded"
