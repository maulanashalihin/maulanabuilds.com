                                    >
                                </div>
                            </div>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                Modern link management platform for teams.
                                Shorten URLs, track clicks with deep analytics,
                                rotate links for A/B testing, generate QR codes,
                                and protect links with passwords. 100% open
                                source with custom branded domains.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="text-xs font-mono text-cyan-400 bg-cyan-950/30 border border-cyan-900/50 px-2 py-1 rounded"
                                    >Open Source</span
                                >
                                <span
                                    class="text-xs font-mono text-gray-400 bg-[#1A1F26] px-2 py-1 rounded"
