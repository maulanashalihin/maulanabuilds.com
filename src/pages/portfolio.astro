                    <!-- DripSender -->
                    <a
                        href="https://dripsender.id"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="block group border border-[#2A2F3A] bg-[#0A0D12] rounded-2xl overflow-hidden hover:border-cyan-500 transition duration-300 hover:shadow-[0_0_30px_rgba(34,211,238,0.1)]"
                    >
                        <div class="p-8">
                            <div class="flex items-center gap-4 mb-4">
                                <div
                                    class="bg-[#14181F] p-3 rounded-lg border border-[#2A2F3A] group-hover:border-cyan-800 transition"
                                >
                                    <img
                                        src="https://dripsender.id/logomark.png"
                                        alt="DripSender logo"
                                        loading="lazy"
                                        width="32"
                                        height="32"
                                        class="w-8 h-8 object-contain"
                                    />
                                </div>
                                <div>
                                    <h3
                                        class="text-xl font-bold text-gray-200 group-hover:text-cyan-400 transition"
                                    >
                                        DripSender
                                    </h3>
                                    <span class="text-xs text-gray-500"
                                        >WhatsApp Marketing Automation</span
                                    >
                                </div>
                            </div>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                Automated WhatsApp marketing platform for
                                businesses to run promotions and manage customer
                                databases without manual intervention. Features
                                scheduled campaigns, unlimited automation
                                chatbots, and AI-powered content generation.
