                                        width="32"
                                        height="32"
                                        class="w-8 h-8 object-contain"
                                    />
                                </div>
                                <div>
                                    <h3
                                        class="text-xl font-bold text-gray-200 group-hover:text-cyan-400 transition"
                                    >
                                        TapSite.ai
                                    </h3>
                                    <span class="text-xs text-gray-500"
                                        >AI Landing Page Builder</span
                                    >
                                </div>
                            </div>
                            <p
                                class="text-sm text-gray-400 mb-6 leading-relaxed"
                            >
                                Indonesia's first AI-powered landing page
                                builder. Create professional websites in ~1
                                minute from your phone—no coding needed. Just
                                chat about your business and get a fully
                                functional site with custom domains, payments,
                                and SEO tools.
                            </p>
                            <div class="flex flex-wrap gap-2">
                                <span
                                    class="text-xs font-mono text-cyan-400 bg-cyan-950/30 border border-cyan-900/50 px-2 py-1 rounded"
                                    >AI-Powered</span
                                >
                                <span
                                    class="text-xs font-mono text-gray-400 bg-[#1A1F26] px-2 py-1 rounded"
