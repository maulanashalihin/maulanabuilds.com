---
import Layout from "../layouts/Layout.astro";
import LucideIcons from "../components/LucideIcons.astro";
import Header from "../components/Header.astro";
---

<Layout>
    <Header />
    <LucideIcons>
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32">
            <div class="max-w-4xl mx-auto text-center">
                <div
                    class="inline-flex items-center gap-2 border border-[#2A2F3A] bg-[#14181F] text-cyan-400 px-4 py-1.5 rounded-full text-sm mb-8"
                >
                    <i data-lucide="layers" class="w-4 h-4"></i>
                    Beyond MVP Development
                </div>
                <h1
                    class="text-4xl md:text-6xl font-bold tracking-tighter leading-[1.1] mb-8"
                >
                    Additional Services.
                </h1>
                <p
                    class="text-xl text-gray-400 max-w-2xl mx-auto leading-relaxed"
                >
                    From technical audits to AI integrations—specialized
                    services for every stage of your startup journey.
                </p>
            </div>
        </section>

        <!-- Core MVP Service (Reference) -->
        <section class="max-w-7xl mx-auto px-6 py-12">
