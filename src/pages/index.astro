---
import Layout from "../layouts/Layout.astro";
import LucideIcons from "../components/LucideIcons.astro";
import Header from "../components/Header.astro";
import BackToTop from "../components/BackToTop.astro";
import Testimonials from "../components/Testimonials.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout>
    <Header />
    <LucideIcons>
        <!-- Skip to content link -->
        <a href="#main-content" class="skip-to-content">Skip to main content</a>

        <main id="main-content">
            <!-- Hero Section -->
            <section
                id="hero"
                class="max-w-7xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32"
            >
                <div class="grid md:grid-cols-12 gap-12 items-center">
                    <div class="md:col-span-8">
                        <div
                            class="inline-flex items-center gap-2 border border-[#2A2F3A] bg-[#14181F] text-cyan-400 px-4 py-1.5 rounded-full text-sm mb-8"
                        >
                            <i data-lucide="shield-check" class="w-4 h-4"></i>
                            Senior Engineer | 100% IP Handover | Production-Grade
                            Code
                        </div>
                        <h1
                            class="text-4xl md:text-6xl font-bold tracking-tighter leading-[1.1] mb-4"
                        >
                            Enterprise-Grade MVP Development. <br />
                            <span class="text-gray-500"
                                >Shipped in 2-4 Weeks.</span
                            >
                        </h1>
                        <p
                            class="text-2xl md:text-3xl font-bold text-emerald-400 mb-8 max-w-2xl leading-relaxed"
                        >
                            <i
                                data-lucide="shield"
                                class="w-6 h-6 inline mr-2 -mt-1"></i>
                            Zero Upfront Financial Risk. 100% Secured via Escrow.com.
                        </p>
                        <p
                            class="text-xl text-gray-400 mb-12 max-w-2xl leading-relaxed"
                        >
                            11+ years of engineering expertise, accelerated by
                            modern tools. I build <strong class="text-gray-300"
                                >secure, scalable, production-ready systems</strong
                            > with proper architecture, testing, and documentation.
                            <strong class="text-cyan-400"
                                >Starting at $5,000.</strong
                            >
                        </p>
                        <div
                            class="flex flex-col sm:flex-row gap-6 items-center"
                        >
                            <a
                                href="/apply"
                                class="w-full sm:w-auto text-center inline-flex items-center justify-center gap-2.5 bg-cyan-500 text-[#0A0D12] font-bold text-lg px-8 py-4 rounded-xl shadow-lg shadow-cyan-900/40 hover:bg-cyan-400 transition duration-300"
                            >
                                Apply for an Architecture Call
                                <i data-lucide="arrow-right" class="w-5 h-5"
                                ></i>
                            </a>
                            <span
                                class="inline-flex items-center gap-1.5 text-emerald-400 text-sm font-medium"
                            >
                                <span
                                    class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"
                                ></span>
                                1 Slot Left This Month
                            </span>
                        </div>
                    </div>
                    <div
                        class="md:col-span-4 hidden md:block border border-[#2A2F3A] bg-[#0F131A] p-6 rounded-2xl shadow-inner"
                    >
                        <div
                            class="flex items-center gap-3 border-b border-[#2A2F3A] pb-4 mb-4"
                        >
                            <i data-lucide="code" class="w-7 h-7 text-cyan-400"
                            ></i>
                            <h3 class="text-lg font-bold text-gray-300">
                                maulanabuilds.com
                            </h3>
                        </div>
                        <div class="space-y-4 text-sm text-gray-500">
                            <p>// Initialize_MVP_Sprint()</p>
                            <p>
                                <span class="text-cyan-400">const</span> timeline
                                = "2-4_weeks";
                            </p>
                            <p>
                                <span class="text-cyan-400">const</span> cost = "$5,000-12,000";
                            </p>
                            <p>
                                <span class="text-cyan-400">const</span> quality =
                                "production_grade";
                            </p>
                            <p>
                                <span class="text-cyan-400">const</span> security
                                = "enterprise_level";
                            </p>
                            <p>
                                <span class="text-cyan-400">const</span> output =
                                "Scalable_System";
                            </p>
                            <p class="text-gray-400 pt-3">
                                // Available: TypeScript, Go, Bun, Rust
                            </p>
                            <p class="text-gray-400">
                                await Maulana.ship_product();
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Value Proposition Section -->
            <section
                id="services"
                class="bg-[#0F131A] py-24 border-t border-[#2A2F3A]"
            >
                <div class="max-w-7xl mx-auto px-6">
                    <div class="grid md:grid-cols-12 gap-12">
                        <div class="md:col-span-5">
                            <div class="sticky top-12">
                                <i
                                    data-lucide="zap"
                                    class="w-10 h-10 text-cyan-400 mb-6"></i>
                                <h2
                                    class="text-3xl md:text-4xl font-bold tracking-tight text-gray-100 mb-6 leading-snug"
                                >
                                    Efficient Validation for Non-Technical
                                    Founders.
                                </h2>
                                <p class="text-gray-400 text-lg max-w-md">
                                    Your biggest risk isn't wrong code—it's
                                    wrong timing. I optimize for velocity and
                                    feedback loops so you can validate faster.
                                </p>
                            </div>
                        </div>

                        <div class="md:col-span-7 space-y-10">
                            <div
                                class="border border-[#2A2F3A] bg-[#0A0D12] p-8 rounded-2xl hover:border-cyan-800 transition"
                            >
                                <i
                                    data-lucide="banknote"
                                    class="w-8 h-8 text-gray-500 mb-4"></i>
                                <h3 class="text-xl font-bold mb-3">
                                    Skip Agency Bureaucracy
                                </h3>
                                <p class="text-gray-400 leading-relaxed">
                                    Don't pay for account managers, sales reps,
                                    and office overhead. At Maulana Builds, you
                                    have direct access to the senior engineer
                                    writing every line of code.
                                </p>
                            </div>
                            <div
                                class="border border-[#2A2F3A] bg-[#0A0D12] p-8 rounded-2xl hover:border-cyan-800 transition"
                            >
                                <i
                                    data-lucide="gauge"
                                    class="w-8 h-8 text-gray-500 mb-4"></i>
                                <h3 class="text-xl font-bold mb-3">
                                    High-Velocity Shipping
                                </h3>
                                <p class="text-gray-400 leading-relaxed">
                                    I leverage 11+ years of battle-tested
                                    boilerplate to launch your MVP in weeks, not
                                    months. While competitors are writing specs,
                                    we're gathering user feedback.
                                </p>
                            </div>
                            <div
                                class="border border-[#2A2F3A] bg-[#0A0D12] p-8 rounded-2xl hover:border-cyan-800 transition"
                            >
                                <i
                                    data-lucide="orbit"
                                    class="w-8 h-8 text-gray-500 mb-4"></i>
                                <h3 class="text-xl font-bold mb-3">
                                    Scalable Architecture
                                </h3>
                                <p class="text-gray-400 leading-relaxed">
                                    I don't just write code—I design systems.
                                    Your MVP will have a solid data foundation
                                    that your future engineering team can scale
                                    with confidence.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Tech Stack Section -->
            <section class="bg-[#0A0D12] py-12 border-t border-[#2A2F3A]">
                <div class="max-w-7xl mx-auto px-6 text-center">
                    <p
                        class="text-xs font-bold tracking-widest text-gray-500 uppercase mb-6"
                    >
                        Engineered with High-Performance Technologies
                    </p>
                    <div
                        class="flex flex-wrap justify-center items-center gap-4 md:gap-8"
                    >
                        <div
                            class="flex items-center gap-2 border border-[#2A2F3A] bg-[#0F131A] px-4 py-2 rounded-lg text-gray-400 text-sm font-mono hover:border-cyan-800 transition cursor-default"
                        >
                            <i
                                data-lucide="layers"
                                class="w-4 h-4 text-cyan-500"></i> React Router v7 / Svelte 5
                        </div>
                        <div
                            class="flex items-center gap-2 border border-[#2A2F3A] bg-[#0F131A] px-4 py-2 rounded-lg text-gray-400 text-sm font-mono hover:border-cyan-800 transition cursor-default"
                        >
                            <i data-lucide="zap" class="w-4 h-4 text-cyan-500"
                            ></i> HyperExpress / Go / Bun
                        </div>

                        <div
                            class="flex items-center gap-2 border border-[#2A2F3A] bg-[#0F131A] px-4 py-2 rounded-lg text-gray-400 text-sm font-mono hover:border-cyan-800 transition cursor-default"
                        >
                            <i
                                data-lucide="database"
                                class="w-4 h-4 text-cyan-500"></i> PostgreSQL / SQLite (WAL Mode)
                        </div>
                        <div
                            class="flex items-center gap-2 border border-[#2A2F3A] bg-[#0F131A] px-4 py-2 rounded-lg text-gray-400 text-sm font-mono hover:border-cyan-800 transition cursor-default"
                        >
                            <i
                                data-lucide="server"
                                class="w-4 h-4 text-cyan-500"></i> VPS / Cloud Server
                            (No Serverless)
                        </div>
                        <div
                            class="flex items-center gap-2 border border-[#2A2F3A] bg-[#0F131A] px-4 py-2 rounded-lg text-gray-400 text-sm font-mono hover:border-cyan-800 transition cursor-default"
                        >
                            <i
                                data-lucide="credit-card"
                                class="w-4 h-4 text-cyan-500"></i> Stripe Integration
                        </div>
                    </div>
                    <div
                        class="mt-8 p-6 border border-emerald-900/50 bg-emerald-950/10 rounded-xl max-w-3xl mx-auto"
                    >
                        <p class="text-sm text-emerald-400 font-bold mb-2">
                            <i
                                data-lucide="gauge"
                                class="w-4 h-4 inline mr-2 -mt-1"></i>
                            Proven Performance: 197,000+ Requests/Second
                        </p>
                        <p class="text-xs text-gray-400 leading-relaxed mb-3">
                            My <strong class="text-gray-300">HyperReact</strong> boilerplate (HyperExpress + Kysely + SQLite) delivers
                            <strong class="text-gray-300">197k RPS with 0.52ms latency</strong>—7.5x faster than Express.js.
                            SQLite WAL mode achieves 22-33x faster writes with near-zero ORM overhead.
                        </p>
                        <div class="space-y-1 text-xs text-gray-400">
                            <p>
                                <span class="text-cyan-400">→</span> 
                                <strong class="text-gray-300">HyperExpress:</strong> 197k RPS vs Express 26k RPS
                            </p>
                            <p>
                                <span class="text-cyan-400">→</span> 
                                <strong class="text-gray-300">SQLite WAL:</strong> 99k ops/sec insert (22x faster than DELETE mode)
                            </p>
                            <p>
                                <span class="text-cyan-400">→</span> 
                                <strong class="text-gray-300">Kysely ORM:</strong> 0-5% overhead vs native better-sqlite3
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 4-Week Blueprint Section -->
            <section class="max-w-7xl mx-auto px-6 py-24 md:py-32">
                <div class="mb-20 text-center md:text-left">
                    <div
                        class="text-cyan-400 text-sm font-bold tracking-widest uppercase mb-3"
                    >
                        // The Specification
                    </div>
                    <h2
                        class="text-3xl md:text-5xl font-bold tracking-tighter text-gray-100 mb-6"
                    >
                        The 4-Week Validation Blueprint
                    </h2>
                    <p class="text-gray-400 text-lg max-w-2xl mx-auto md:mx-0">
                        Every core component necessary to acquire, retain, and
                        charge your early adopters.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                    <div
                        class="border-t-2 border-cyan-800 bg-[#0F131A] p-8 rounded-b-xl space-y-4"
                    >
                        <div class="flex items-center gap-3">
                            <i
                                data-lucide="layout-dashboard"
                                class="w-6 h-6 text-cyan-400"></i>
                            <h3 class="text-lg font-bold text-gray-200">
                                Core Feature App
                            </h3>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            Fully working Web or Mobile application focused on
                            the ONE main value proposition that solves your
                            users' pain.
                        </p>
                    </div>
                    <div
                        class="border-t-2 border-cyan-800 bg-[#0F131A] p-8 rounded-b-xl space-y-4"
                    >
                        <div class="flex items-center gap-3">
                            <i
                                data-lucide="key-round"
                                class="w-6 h-6 text-cyan-400"></i>
                            <h3 class="text-lg font-bold text-gray-200">
                                Secure Admin Panel
                            </h3>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            Complete backend control dashboard to manage users,
                            data flows, and view critical business KPIs.
                        </p>
                    </div>
                    <div
                        class="border-t-2 border-cyan-800 bg-[#0F131A] p-8 rounded-b-xl space-y-4"
                    >
                        <div class="flex items-center gap-3">
                            <i
                                data-lucide="credit-card"
                                class="w-6 h-6 text-cyan-400"></i>
                            <h3 class="text-lg font-bold text-gray-200">
                                Payments Integration
                            </h3>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            Stripe or PayPal setup. Your users can complete
                            transactions on Day 1 of launch.
                        </p>
                    </div>
                    <div
                        class="border-t-2 border-cyan-800 bg-[#0F131A] p-8 rounded-b-xl space-y-4"
                    >
                        <div class="flex items-center gap-3">
                            <i
                                data-lucide="hard-drive-download"
                                class="w-6 h-6 text-cyan-400"></i>
                            <h3 class="text-lg font-bold text-gray-200">
                                Production Deploy
                            </h3>
                        </div>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            Full deployment on dedicated cloud servers (VPS)
                            with secured database, SSL, and predictable monthly
                            costs. No serverless vendor lock-in, no surprise
                            bills.
                        </p>
                    </div>
                </div>
            </section>

            <!-- Pricing Section -->
            <section
                class="max-w-7xl mx-auto px-6 py-24 border-t border-[#2A2F3A]"
            >
                <div class="mb-16 text-center">
                    <div
                        class="text-cyan-400 text-sm font-bold tracking-widest uppercase mb-3"
                    >
                        // Investment
                    </div>
                    <h2
                        class="text-3xl md:text-5xl font-bold tracking-tighter text-gray-100 mb-6"
                    >
                        Simple, Transparent Pricing.
                    </h2>
                    <p class="text-gray-400 text-lg max-w-3xl mx-auto">
                        11+ years of engineering expertise, accelerated by
                        modern tools.
                        <strong class="text-gray-300"
                            >Production-ready systems with proper architecture,
                            security, and testing.</strong
                        >
                    </p>
                </div>

                <!-- Agency Comparison -->
                <div
                    class="max-w-4xl mx-auto mb-12 p-6 border border-cyan-800 bg-[#0F131A] rounded-xl"
                >
                    <div
                        class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center"
                    >
                        <div>
                            <div class="text-sm text-gray-500 mb-2">
                                🏢 Traditional Agency
                            </div>
                            <div class="text-2xl font-bold text-gray-400">
                                $25,000-50,000
                            </div>
                            <div class="text-xs text-gray-600 mt-1">
                                8-12 weeks delivery
                            </div>
                        </div>
                        <div class="border-l border-r border-[#2A2F3A]">
                            <div class="text-sm text-cyan-400 mb-2">
                                🚀 Maulana Builds
                            </div>
                            <div class="text-2xl font-bold text-cyan-400">
                                $5,000-12,000
                            </div>
                            <div class="text-xs text-gray-600 mt-1">
                                2-4 weeks delivery
                            </div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-500 mb-2">
                                💡 You Save
                            </div>
                            <div class="text-2xl font-bold text-emerald-400">
                                70-80%
                            </div>
                            <div class="text-xs text-gray-600 mt-1">
                                3-4x faster launch
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto"
                >
                    <!-- Starter Tier -->
                    <div
                        class="border border-[#2A2F3A] bg-[#0A0D12] p-8 rounded-2xl hover:border-cyan-800 transition"
                    >
                        <div class="mb-6">
                            <h3 class="text-2xl font-bold text-gray-200 mb-2">
                                Starter
                            </h3>
                            <p class="text-gray-500 text-sm">
                                Validated MVP with solid foundation
                            </p>
                        </div>
                        <div class="mb-6">
                            <span class="text-4xl font-bold text-cyan-400"
                                >$5,000</span
                            >
                            <span class="text-gray-500 text-sm block mt-1"
                                >1-2 weeks delivery</span
                            >
                        </div>
                        <ul class="space-y-3 mb-8">
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                1-2 Core features (fully polished)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Secure authentication (Session-based/OAuth)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Database design with proper indexing
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                API documentation (OpenAPI/Swagger)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Security: SQL injection prevention, XSS protection
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Deployment with CI/CD pipeline
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                14-day bug fix warranty
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-gray-500 shrink-0"></i>
                                Communication: Email updates (weekly)
                            </li>
                        </ul>
                        <a
                            href="/apply"
                            class="w-full inline-flex items-center justify-center gap-2 border border-[#2A2F3A] bg-[#14181F] text-gray-300 px-6 py-3 rounded-xl hover:border-cyan-800 hover:text-cyan-400 transition font-medium"
                        >
                            Start Starter Project
                            <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </a>
                    </div>

                    <!-- Growth Tier -->
                    <div
                        class="border-2 border-cyan-800 bg-gradient-to-b from-[#0F131A] to-[#0A0D12] p-8 rounded-2xl relative"
                    >
                        <div
                            class="absolute -top-4 left-1/2 -translate-x-1/2 bg-cyan-500 text-[#0A0D12] text-xs font-bold px-4 py-1 rounded-full"
                        >
                            MOST POPULAR
                        </div>
                        <div class="mb-6">
                            <h3 class="text-2xl font-bold text-gray-200 mb-2">
                                Growth
                            </h3>
                            <p class="text-gray-500 text-sm">
                                Full-featured product ready to scale
                            </p>
                        </div>
                        <div class="mb-6">
                            <span class="text-4xl font-bold text-cyan-400"
                                >$8,000</span
                            >
                            <span class="text-gray-500 text-sm block mt-1"
                                >2-3 weeks delivery</span
                            >
                        </div>
                        <ul class="space-y-3 mb-8">
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Up to 5 core features (production-ready)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Full admin dashboard with analytics
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Payment integration (Stripe/PayPal)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Role-based access control (RBAC)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Database optimization + query indexing
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Security: OWASP best practices
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Load testing (10,000+ concurrent users)
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                30-day bug fix warranty + 1 month support
                            </li>
                            <li
                                class="flex items-start gap-3 text-sm text-gray-400"
                            >
                                <i
                                    data-lucide="circle-check"
                                    class="w-5 h-5 text-cyan-500 shrink-0"></i>
                                Communication: Slack + Email (priority response)
                            </li>
                        </ul>
