---
import '../styles/global.css';
interface Props {
	title?: string;
}

const { title = 'Maulana Builds | High-Fidelity Startup MVPs in 4 Weeks' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-[#0A0D12] text-gray-100 antialiased grid-bg">
		<slot />
	</body>
</html>
